{
  "name": "claude-sessions",
  "displayName": "Claude Sessions",
  "description": "Central sidebar for Claude Code activity: sessions across projects (with tokens/cost/subagents/projects-touched), KB file changes by day, and per-project file changes by day. Jump to resume, file, or diff.",
  "version": "0.8.0",
  "publisher": "zhirafovod",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhirafovod/claude-sessions-vscode.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:claudeSessions",
    "onView:claudeKbChanges",
    "onView:claudeProjectsActivity"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-activity",
          "title": "Claude Activity",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "claude-activity": [
        {
          "id": "claudeSessions",
          "name": "Sessions",
          "icon": "$(history)",
          "contextualTitle": "Claude Sessions"
        },
        {
          "id": "claudeKbChanges",
          "name": "KB changes",
          "icon": "$(book)",
          "contextualTitle": "Knowledge base file changes"
        },
        {
          "id": "claudeProjectsActivity",
          "name": "Projects",
          "icon": "$(folder-active)",
          "contextualTitle": "Per-project file changes"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeSessions.refresh",
        "title": "Refresh sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeSessions.resume",
        "title": "Resume session"
      },
      {
        "command": "claudeSessions.openTranscript",
        "title": "Open transcript (JSONL)"
      },
      {
        "command": "claudeSessions.viewConversation",
        "title": "View conversation",
        "icon": "$(preview)"
      },
      {
        "command": "claudeSessions.openInsights",
        "title": "Open insights dashboard",
        "icon": "$(graph)"
      },
      {
        "command": "claudeSessions.classifyTopics",
        "title": "Analyze conversation topics"
      },
      {
        "command": "claudeSessions.showAgentGraph",
        "title": "Show 2D agent graph",
        "icon": "$(circuit-board)"
      },
      {
        "command": "claudeSessions.showTrajectory",
        "title": "Show conversation trajectory"
      },
      {
        "command": "claudeKbChanges.refresh",
        "title": "Refresh KB changes",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeKbChanges.openFile",
        "title": "Open file"
      },
      {
        "command": "claudeKbChanges.diff",
        "title": "Show diff against HEAD~1"
      },
      {
        "command": "claudeProjectsActivity.refresh",
        "title": "Refresh project activity",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeProjectsActivity.openFile",
        "title": "Open file"
      },
      {
        "command": "claudeProjectsActivity.diff",
        "title": "Show diff against HEAD~1"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeSessions.openInsights",
          "when": "view == claudeSessions",
          "group": "navigation@1"
        },
        {
          "command": "claudeSessions.showAgentGraph",
          "when": "view == claudeSessions",
          "group": "navigation@2"
        },
        {
          "command": "claudeSessions.refresh",
          "when": "view == claudeSessions",
          "group": "navigation@3"
        },
        {
          "command": "claudeKbChanges.refresh",
          "when": "view == claudeKbChanges",
          "group": "navigation"
        },
        {
          "command": "claudeProjectsActivity.refresh",
          "when": "view == claudeProjectsActivity",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeSessions.openTranscript",
          "when": "view == claudeSessions && viewItem == session",
          "group": "inline"
        },
        {
          "command": "claudeKbChanges.diff",
          "when": "view == claudeKbChanges && viewItem == fileChange",
          "group": "inline"
        },
        {
          "command": "claudeProjectsActivity.diff",
          "when": "view == claudeProjectsActivity && viewItem == fileChange",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Claude Sessions",
      "properties": {
        "claudeSessions.limit": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of most-recent sessions to load."
        },
        "claudeSessions.scriptPath": {
          "type": "string",
          "default": "~/.claude/skills/sessions/session-center.sh",
          "description": "Path to session-center.sh (fallback when cacheEnabled is false)."
        },
        "claudeSessions.cacheEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Use the SQLite cache. When true (default), the sidebar reads from a local DB and only re-parses JSONLs whose (mtime,size) changed. When false, falls back to spawning session-center.sh on every refresh (v0.6.x behavior)."
        },
        "claudeSessions.showAutomated": {
          "type": "boolean",
          "default": false,
          "description": "Show automated / cron-triggered sessions (entrypoint = sdk-cli, sdk, routine, etc.). Hidden by default since they're usually scheduled jobs (Google Doc digests, KB ingest, daily reports) rather than interactive work."
        },
        "claudeSessions.insightsLookbackDays": {
          "type": "number",
          "default": 14,
          "description": "Insights dashboard: how many days of activity to chart."
        },
        "claudeSessions.insightsDeepParse": {
          "type": "number",
          "default": 20,
          "description": "Insights dashboard: how many most-recent sessions to parse deeply for thinking-time / tool-mix / burst-rate metrics. Higher = better stats, slower load."
        },
        "claudeKbChanges.repoPath": {
          "type": "string",
          "default": "~/docs",
          "description": "Path to the KB git repo whose changes will be listed."
        },
        "claudeKbChanges.lookbackDays": {
          "type": "number",
          "default": 14,
          "description": "How many days of git history to load."
        },
        "claudeProjectsActivity.repoPaths": {
          "type": "array",
          "default": [
            "~/projects/unpolarize",
            "~/projects/ai/otelo"
          ],
          "description": "Explicit list of project repos to watch. Auto-discovery is also applied (any ~/projects/* with commits in the lookback)."
        },
        "claudeProjectsActivity.autoDiscover": {
          "type": "boolean",
          "default": true,
          "description": "Walk ~/projects/ (depth 2) and include any git repo with commits in the lookback window."
        },
        "claudeProjectsActivity.discoveryRoot": {
          "type": "string",
          "default": "~/projects",
          "description": "Root for auto-discovery (depth 2)."
        },
        "claudeProjectsActivity.lookbackDays": {
          "type": "number",
          "default": 14,
          "description": "How many days of git history to load per project."
        },
        "claudeSessions.classify.backend": {
          "type": "string",
          "enum": ["ollama", "claude-p"],
          "default": "ollama",
          "description": "Where topic classification runs. `ollama` calls a local Ollama daemon (free, offline). `claude-p` invokes the Claude CLI in headless mode, using your subscription."
        },
        "claudeSessions.classify.model": {
          "type": "string",
          "default": "llama3.2:3b",
          "description": "Model id passed to the chosen classification backend. For `ollama`, try `llama3.2:3b`, `qwen2.5:3b`, `gemma2:2b`. For `claude-p`, try `claude-haiku-4-5`."
        },
        "claudeSessions.classify.batchSize": {
          "type": "number",
          "default": 20,
          "description": "How many turns to classify per backend invocation."
        },
        "claudeSessions.classify.claudeBin": {
          "type": "string",
          "default": "",
          "description": "Optional override for the `claude` CLI path. Only used when `classify.backend = claude-p`. Empty = use PATH."
        },
        "claudeSessions.embedding.preferred": {
          "type": "string",
          "enum": [
            "ollama",
            "transformersjs"
          ],
          "default": "ollama",
          "description": "Which embedding backend to try first for the agent graph."
        },
        "claudeSessions.embedding.ollamaUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Base URL for a local Ollama daemon."
        },
        "claudeSessions.embedding.ollamaModel": {
          "type": "string",
          "default": "nomic-embed-text",
          "description": "Ollama embedding model name."
        },
        "claudeSessions.embedding.transformersjsModel": {
          "type": "string",
          "default": "Xenova/bge-small-en-v1.5",
          "description": "Transformers.js fallback model id."
        },
        "claudeSessions.cluster.minPts": {
          "type": "number",
          "default": 5,
          "description": "DBSCAN minPts for clustering sessions on the agent graph."
        },
        "claudeSessions.cluster.epsScale": {
          "type": "number",
          "default": 0.04,
          "description": "DBSCAN eps as a fraction of the agent graph's axis range. Smaller = tighter clusters."
        },
        "claudeSessions.trajectory.driftPercentile": {
          "type": "number",
          "default": 90,
          "description": "Segments above this percentile of cosine distance between consecutive turns are flagged as topic drift in the trajectory view."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "rebuild-native": "electron-rebuild --version 39.8.8 --module-dir . --types prod",
    "package": "npm run compile && npm run rebuild-native && vsce package --allow-missing-repository",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "umap-js": "^1.4.0"
  }
}
